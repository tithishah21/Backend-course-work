<!-- prouducts page - customers  -->

<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/product.css">
</head>

<body>
    <%- include('../includes/navigation.ejs') %>

    <main>
        <% if(prods.length > 0) { %>
            <div class="grid">
                <% for (let i of prods) { %>
                    <article class="card product-item">
                        <header class="card__header">
                            <h1 class="product__title"><%= i.title %></h1>
                        </header>
                        <div class="card__image">
                            <img src="<%= i.imageUrl%>" alt="<%= i.title %>">
                        </div>
                        <div class="card__content">
                            <h2 class="product__price">$<%= i.price %></h2>
                            <p class="product__description"><%= i.description %></p>
                        </div>
                        <div class="card__actions">
                            <a href="/products/<%= i.id %>" class="btn">Details</a>
                            <%- include('../includes/add-to-cart.ejs', {product: i}) %>
                        </div>
                    </article>
                <% } %>
            </div> 
        <% } else { %>
            <h1> No Products </h1>
        <% } %>
    </main>
    <%- include('../includes/end.ejs') %>
